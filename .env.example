# === Supabase ===
# Project URL — Supabase Dashboard -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key — Dashboard -> Project Settings -> API -> Project API keys -> anon / public
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# === Site URL (auth redirects) ===
# Canonical origin used for email-confirmation, password-reset and Google OAuth
# redirects. Set this in Vercel to the production domain so links never point at
# localhost. Leave UNSET locally to fall back to the current window origin.
#   Production: VITE_SITE_URL=https://chainwork-team.vercel.app
VITE_SITE_URL=

# === Web Push (notifications) ===
# Public VAPID key — ships in the client bundle (NOT secret). Generate a pair with
# `npx web-push generate-vapid-keys`. A default is hardcoded in src/lib/push.ts, but
# set this to override it.
VITE_VAPID_PUBLIC_KEY=

# --- Server-only (set these in Vercel → Project → Settings → Environment Variables) ---
# Private VAPID key (pairs with the public one above). NEVER commit / never VITE_.
VAPID_PRIVATE_KEY=
# Contact subject for push services.
VAPID_SUBJECT=mailto:agustincasal@impulsex.com.ar
# Supabase service-role key — Dashboard → Project Settings → API → service_role.
# Lets /api/* read every user's push subscription and send to all members.
SUPABASE_SERVICE_ROLE_KEY=
# Random string Vercel Cron uses to authorize /api/notify-due (set the same value
# in Vercel). Generate e.g. with `openssl rand -hex 32`.
CRON_SECRET=
