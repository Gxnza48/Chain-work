# === Supabase ===
# Project URL — Supabase Dashboard -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key — Dashboard -> Project Settings -> API -> Project API keys -> anon / public
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# === Site URL (auth redirects) ===
# Canonical origin used for email-confirmation, password-reset and Google OAuth
# redirects. Set this in Vercel to the production domain so links never point at
# localhost. Leave UNSET locally to fall back to the current window origin.
#   Production: VITE_SITE_URL=https://chainwork-team.vercel.app
VITE_SITE_URL=
